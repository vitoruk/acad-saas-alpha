# =========================================
# ACAD-SaaS — Variáveis de ambiente
# =========================================

# --- Ambiente ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=super-secret-jwt

# --- Cofre de certificados (KEK AES-256-GCM base64) ---
# Gere com: openssl rand -base64 32
PFX_KEK_BASE64=REPLACE_WITH_32_BYTES_BASE64
PFX_KEK_VERSION=1

# --- PFX de teste (desenvolvimento) ---
TEST_PFX_PATH=./certs/test-a1.pfx
TEST_PFX_PASSWORD=alpha123

# --- IES (single-tenant: Faculdade Alpha Recife-PE) ---
IES_CODIGO_EMEC=0000
IES_CNPJ=00.000.000/0001-00
IES_NOME="Faculdade Alpha"
IES_UF=PE
IES_MUNICIPIO=Recife

# --- Validador público ---
VALIDADOR_PUBLIC_URL=https://valida.acadsaas.br

# --- Resend (e-mail) ---
RESEND_API_KEY=re_xxx
RESEND_FROM="ACAD-SaaS <noreply@acadsaas.br>"

# --- OpenTimestamps ---
OTS_CALENDARS=https://alice.btc.calendar.opentimestamps.org,https://bob.btc.calendar.opentimestamps.org,https://finney.calendar.eternitywall.com

# --- Cloudflare (opcional, p/ scripts) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- CORS allowlist (separado por vírgula) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.acadsaas.br

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
