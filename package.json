{
  "name": "acad-saas",
  "version": "0.1.0",
  "private": true,
  "description": "ACAD-SaaS — ERP Acadêmico + Secretaria Digital + Diploma Digital MEC",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
