    "cert:gen-test": "bash scripts/gen-test-cert.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.11.0 <21"
  }
}
