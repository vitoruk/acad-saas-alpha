{
  "name": "@acad-saas/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts src/validador.ts --format esm --out-dir dist --clean",
    "start": "node dist/server.js",
    "start:validador": "node dist/validador.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@supabase/supabase-js": "^2.45.4",
    "@xmldom/xmldom": "^0.9.3",
    "axios": "^1.7.7",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.3.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.5.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "resend": "^4.0.0",
    "xml-crypto": "^6.0.0",
    "xpath": "^0.0.34",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.5",
    "@types/node-forge": "^1.3.11",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
